@page
@model Civiti.Auth.Pages.ConsentModel
@{
    ViewData["Title"] = "Authorize";
}

<h2>
    @Model.ClientDisplayName
    @if (Model.IsTrusted)
    {
        <span class="badge badge-verified">Verified</span>
    }
    else
    {
        <span class="badge badge-unverified">Unverified</span>
    }
</h2>
<p>This application is asking to access your Civiti account.</p>

<form method="post">
    @* OAuth context (clientId, scopes, redirect_uri, state, original /authorize URL) is read
       server-side from the Data-Protection-encrypted civiti_auth_consent_ctx cookie set by
       /authorize, not from form fields the user can edit. The hidden Nonce below is the only
       payload beyond the antiforgery token: it ties THIS form to the cookie that rendered it,
       so a concurrent /authorize in another tab overwriting the cookie causes this submit to
       fail with 400 instead of silently committing consent for the other tab's client. *@
    <input type="hidden" asp-for="Nonce" />

    <h3 style="margin-top:1.25rem;font-size:0.95rem;">It will be able to:</h3>
    <ul class="scope-list">
        @foreach (var scope in Model.Scopes)
        {
            <li>
                <span class="scope-bullet" aria-hidden="true">•</span>
                <span>
                    <span class="scope-name">@scope.DisplayName</span>
                    <span class="scope-desc">@scope.Description</span>
                </span>
            </li>
        }
    </ul>

    @if (Model.StrippedScopes.Count > 0)
    {
        <p class="error" role="status">
            The following scopes were requested but cannot be granted:
            <strong>@string.Join(", ", Model.StrippedScopes)</strong>
            (your account isn't authorized for them).
        </p>
    }

    <p class="gdpr-notice">
        <strong>Privacy notice (placeholder — pending product/legal review):</strong>
        Data returned by Civiti tools flows to your AI assistant's provider (Anthropic, OpenAI, …) according to their terms.
        Civiti does not control how that provider stores, processes, or shares the data after it leaves us.
        Approving here grants the listed permissions until you revoke them in your Civiti account settings.
    </p>

    <div class="actions">
        <button type="submit" asp-page-handler="Deny" class="btn-secondary">Deny</button>
        <button type="submit">Approve</button>
    </div>
</form>
